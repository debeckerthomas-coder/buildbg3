---
// src/pages/outils/carte.astro
// Carte interactive BG3 — MapGenie embed (iframe) + fallback Leaflet

import BaseLayout from '../../layouts/BaseLayout.astro';
import TopBar from '../../components/TopBar.astro';

const currentPath = Astro.url.pathname;

const acts = [
  {
    id: 1,
    label: 'Acte 1',
    sublabel: 'Forêt Interdite',
    color: '#4ade80',
    colorRgb: '74,222,128',
    mapgenieUrl: 'https://mapgenie.io/baldurs-gate-3/maps/wilderness?embed=1',
    mapgenieLink: 'https://mapgenie.io/baldurs-gate-3/maps/wilderness',
  },
  {
    id: 2,
    label: 'Acte 2',
    sublabel: 'Terres maudites',
    color: '#818cf8',
    colorRgb: '129,140,248',
    mapgenieUrl: 'https://mapgenie.io/baldurs-gate-3/maps/shadow-cursed-lands?embed=1',
    mapgenieLink: 'https://mapgenie.io/baldurs-gate-3/maps/shadow-cursed-lands',
  },
  {
    id: 3,
    label: 'Acte 3',
    sublabel: "Baldur's Gate",
    color: '#f97316',
    colorRgb: '249,115,22',
    mapgenieUrl: 'https://mapgenie.io/baldurs-gate-3/maps/baldurs-gate?embed=1',
    mapgenieLink: 'https://mapgenie.io/baldurs-gate-3/maps/baldurs-gate',
  },
];

const lockadinPoints = [
  {
    act: 1,
    actLabel: 'Acte 1',
    actColor: '#4ade80',
    item: 'Everburn Blade',
    type: 'weapon',
    typeLabel: 'Arme',
    location: 'Nautiloïde — Commandeur Zhalk',
    desc: "Battez Commandeur Zhalk sur le Nautiloïde (tutoriel). Utilisez les démons pour affaiblir Zhalk, récupérez l'épée avant d'évacuer.",
    priority: 'S',
  },
  {
    act: 1,
    actLabel: 'Acte 1',
    actColor: '#4ade80',
    item: 'Devotee\'s Mace',
    type: 'weapon',
    typeLabel: 'Arme',
    location: 'Camp Gobelin — Sombrecœur (Forêt Interdite)',
    desc: "Lootée sur l'Archiprêtresse Gut ou achetée au camp après avoir neutralisé les chefs Gobelins. Idéale pour Paladine early.",
    priority: 'A',
  },
  {
    act: 1,
    actLabel: 'Acte 1',
    actColor: '#4ade80',
    item: 'Amulet of Misty Step',
    type: 'accessory',
    typeLabel: 'Accessoire',
    location: 'Camp Gobelin — Archiprêtresse Gut',
    desc: "Lootée sur Gut après l'avoir vaincue dans la salle de torture. Donne un sort de Pas brumeux gratuit — mobilité clé pour le Lockadin.",
    priority: 'A',
  },
  {
    act: 3,
    actLabel: 'Acte 3',
    actColor: '#f97316',
    item: 'Helldusk Armor',
    type: 'armor',
    typeLabel: 'Armure',
    location: "Maison de l'Espoir (Acte 3)",
    desc: "Armure légendaire dans le coffre de Raphael à la Maison de l'Espoir. CA 21, résistances, vol magique. Pièce BiS absolue du Lockadin.",
    priority: 'S',
  },
  {
    act: 3,
    actLabel: 'Acte 3',
    actColor: '#f97316',
    item: 'Nyrulna',
    type: 'weapon',
    typeLabel: 'Arme',
    location: "Acte 3 — Circus of the Last Days (Lave)",
    desc: "Trident légendaire obtenu dans la fosse de lave du Circus of the Last Days. Dégâts de tonnerre + foudre, parfait pour variante Occultiste.",
    priority: 'A',
  },
];
---

<BaseLayout
  title="Carte Interactive BG3 — MapGenie"
  description="Carte interactive des zones de Baldur's Gate 3 — Acte 1 (Forêt Interdite), Acte 2 (Terres maudites), Acte 3 (Baldur's Gate). Points clés Lockadin Mode Honneur."
>
  <TopBar currentSection="outils" currentPath={currentPath} />

  <main class="min-h-screen" style="background: #05060a;">

    <!-- En-tête -->
    <section class="px-4 pt-8 pb-4 max-w-content mx-auto">
      <div class="flex items-center gap-3 mb-2">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
             stroke-linecap="round" stroke-linejoin="round"
             class="w-6 h-6 shrink-0" style="color: #d4a857;" aria-hidden="true">
          <polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/>
          <line x1="9" x2="9" y1="3" y2="18"/>
          <line x1="15" x2="15" y1="6" y2="21"/>
        </svg>
        <h1 class="font-display text-2xl" style="color: #d4a857;">Carte Interactive</h1>
      </div>
      <p style="color: #9a8a72; font-size: 0.875rem;">
        Explorez Faerûn acte par acte via MapGenie — cliquez sur les marqueurs pour retrouver quêtes, boss et équipement.
      </p>
    </section>

    <!-- Onglets Actes -->
    <section class="px-4 pb-3 max-w-content mx-auto">
      <div class="flex flex-wrap gap-2" role="tablist" aria-label="Sélection de l'acte">
        {acts.map((act, i) => (
          <button
            id={`tab-act${act.id}`}
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-controls={`panel-act${act.id}`}
            data-act={act.id}
            style={i === 0
              ? `padding:6px 16px;border-radius:4px;font-size:0.8rem;font-weight:600;letter-spacing:0.06em;cursor:pointer;border:1px solid ${act.color};background:rgba(${act.colorRgb},0.15);color:${act.color};transition:background 0.15s,border-color 0.15s;`
              : `padding:6px 16px;border-radius:4px;font-size:0.8rem;font-weight:600;letter-spacing:0.06em;cursor:pointer;border:1px solid rgba(${act.colorRgb},0.35);background:transparent;color:${act.color};transition:background 0.15s,border-color 0.15s;`
            }
          >
            {act.label}
            <span style={`font-weight:400;font-size:0.72rem;margin-left:5px;opacity:0.75;`}>
              {act.sublabel}
            </span>
          </button>
        ))}
      </div>
    </section>

    <!-- Panneaux carte (un par acte) -->
    {acts.map((act, i) => (
      <section
        id={`panel-act${act.id}`}
        role="tabpanel"
        aria-labelledby={`tab-act${act.id}`}
        class="px-4 pb-4 max-w-content mx-auto"
        style={i !== 0 ? 'display:none;' : ''}
      >
        <!-- iframe MapGenie -->
        <div style="position:relative;width:100%;border:1px solid rgba(212,168,87,0.25);border-radius:8px;overflow:hidden;background:#0d0f1a;">
          <!-- Bannière de chargement (cachée quand iframe charge) -->
          <div
            id={`loading-${act.id}`}
            style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;background:#05060a;z-index:2;pointer-events:none;"
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="#d4a857" stroke-width="1.5"
                 stroke-linecap="round" stroke-linejoin="round"
                 style="width:2rem;height:2rem;opacity:0.6;" aria-hidden="true">
              <polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/>
              <line x1="9" x2="9" y1="3" y2="18"/>
              <line x1="15" x2="15" y1="6" y2="21"/>
            </svg>
            <span style="color:#9a8a72;font-size:0.8rem;">Chargement de la carte…</span>
          </div>

          <iframe
            id={`iframe-act${act.id}`}
            src={act.mapgenieUrl}
            width="100%"
            height="650"
            frameborder="0"
            allowfullscreen
            loading={i === 0 ? 'eager' : 'lazy'}
            title={`Carte MapGenie BG3 — ${act.label} : ${act.sublabel}`}
            style="display:block;border:none;width:100%;height:650px;"
          ></iframe>
        </div>

        <!-- Lien MapGenie plein écran -->
        <div style="margin-top:10px;display:flex;justify-content:flex-end;">
          <a
            href={act.mapgenieLink}
            target="_blank"
            rel="noopener noreferrer"
            style={`display:inline-flex;align-items:center;gap:6px;font-size:0.78rem;font-weight:600;color:${act.color};text-decoration:none;padding:5px 12px;border:1px solid rgba(${act.colorRgb},0.3);border-radius:4px;background:rgba(${act.colorRgb},0.08);transition:background 0.15s;`}
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round"
                 style="width:0.9rem;height:0.9rem;" aria-hidden="true">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
              <polyline points="15 3 21 3 21 9"/>
              <line x1="10" x2="21" y1="14" y2="3"/>
            </svg>
            Ouvrir dans MapGenie
          </a>
        </div>
      </section>
    ))}

    <!-- Points clés Lockadin -->
    <section class="px-4 pb-6 max-w-content mx-auto">
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:1rem;border-bottom:1px solid rgba(212,168,87,0.2);padding-bottom:0.5rem;">
        <svg viewBox="0 0 24 24" fill="none" stroke="#d4a857" stroke-width="1.5"
             stroke-linecap="round" stroke-linejoin="round"
             style="width:1.1rem;height:1.1rem;flex-shrink:0;" aria-hidden="true">
          <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
        </svg>
        <h2 class="font-display text-lg" style="color:#d4a857;">Points clés — Équipement BiS Lockadin</h2>
        <span style="font-size:0.65rem;text-transform:uppercase;letter-spacing:0.08em;color:#d4a857;background:rgba(212,168,87,0.12);border:1px solid rgba(212,168,87,0.25);padding:1px 7px;border-radius:3px;white-space:nowrap;">
          Mode Honneur
        </span>
      </div>
      <p style="color:#7a6a58;font-size:0.8rem;margin-bottom:1rem;line-height:1.5;">
        Les pièces d'équipement incontournables pour votre Lockadin — localisez-les sur la carte MapGenie ci-dessus.
      </p>

      <div class="grid gap-3 md:grid-cols-2 lg:grid-cols-3">
        {lockadinPoints.map(pt => {
          const typeColors = { weapon: '#ef4444', armor: '#818cf8', accessory: '#d4a857' };
          const typeIcons = { weapon: '⚔', armor: '🛡', accessory: '💎' };
          const priorityColors = { S: '#d4a857', A: '#4ade80' };
          const c = typeColors[pt.type] || '#9a8a72';
          const ic = typeIcons[pt.type] || '★';
          const pc = priorityColors[pt.priority] || '#9a8a72';
          return (
            <div style={`background:rgba(13,15,26,0.8);border:1px solid rgba(212,168,87,0.15);border-radius:8px;padding:14px 16px;display:flex;flex-direction:column;gap:8px;`}>
              <!-- En-tête item -->
              <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px;">
                <div style="display:flex;align-items:center;gap:8px;flex:1;min-width:0;">
                  <span style={`width:30px;height:30px;border-radius:6px;background:${c}18;border:1px solid ${c}40;display:inline-flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0;`}>
                    {ic}
                  </span>
                  <span style="color:#e8dcc8;font-weight:700;font-size:0.9rem;line-height:1.2;">{pt.item}</span>
                </div>
                <div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px;flex-shrink:0;">
                  <span style={`font-size:0.62rem;font-weight:800;letter-spacing:0.1em;color:${pc};background:${pc}15;border:1px solid ${pc}30;padding:1px 6px;border-radius:3px;`}>
                    Tier {pt.priority}
                  </span>
                  <span style={`font-size:0.62rem;text-transform:uppercase;letter-spacing:0.07em;color:${pt.actColor};`}>
                    {pt.actLabel}
                  </span>
                </div>
              </div>

              <!-- Type -->
              <div style={`font-size:0.68rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:${c};`}>
                {pt.typeLabel}
              </div>

              <!-- Lieu -->
              <div style="display:flex;align-items:flex-start;gap:6px;">
                <svg viewBox="0 0 24 24" fill="none" stroke="#9a8a72" stroke-width="1.5"
                     stroke-linecap="round" stroke-linejoin="round"
                     style="width:0.85rem;height:0.85rem;flex-shrink:0;margin-top:1px;" aria-hidden="true">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
                <span style="color:#9a8a72;font-size:0.78rem;line-height:1.4;">{pt.location}</span>
              </div>

              <!-- Description -->
              <p style="color:#7a6a58;font-size:0.76rem;line-height:1.5;margin:0;">{pt.desc}</p>
            </div>
          );
        })}
      </div>
    </section>

    <!-- Instructions d'utilisation -->
    <section class="px-4 pb-12 max-w-content mx-auto">
      <div style="background:rgba(212,168,87,0.05);border:1px solid rgba(212,168,87,0.18);border-radius:8px;padding:16px 20px;">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
          <svg viewBox="0 0 24 24" fill="none" stroke="#d4a857" stroke-width="1.5"
               stroke-linecap="round" stroke-linejoin="round"
               style="width:1rem;height:1rem;flex-shrink:0;" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <path d="M12 16v-4"/>
            <path d="M12 8h.01"/>
          </svg>
          <span style="color:#d4a857;font-size:0.82rem;font-weight:700;">Comment utiliser la carte</span>
        </div>
        <ul style="color:#7a6a58;font-size:0.78rem;line-height:1.7;margin:0;padding-left:1.2rem;list-style:disc;">
          <li>Sélectionnez l'acte via les onglets pour charger la carte MapGenie correspondante.</li>
          <li>Utilisez les filtres dans MapGenie (panneau gauche) pour afficher uniquement les catégories qui vous intéressent : boss, quêtes, trésors…</li>
          <li>Cliquez sur <strong style="color:#e8dcc8;">Ouvrir dans MapGenie</strong> pour accéder à la version plein écran avec toutes les fonctionnalités (liste de contrôle, compte utilisateur…).</li>
          <li>Les items BiS Lockadin listés ci-dessus sont tous localisables via la barre de recherche MapGenie.</li>
        </ul>
      </div>
    </section>

  </main>

  <style>
    /* Masque le spinner une fois l'iframe chargée */
    iframe.loaded + * { display: none !important; }
    /* Responsive : réduire la hauteur des iframes sur mobile */
    @media (max-width: 640px) {
      iframe[id^="iframe-act"] {
        height: 420px !important;
      }
    }
    /* Hover sur les liens MapGenie */
    a[href*="mapgenie"]:hover {
      filter: brightness(1.1);
    }
  </style>

  <script is:inline>
    // ── Gestion des onglets ──────────────────────────────────────────
    var actsConfig = [
      { id: 1, color: '#4ade80', rgb: '74,222,128' },
      { id: 2, color: '#818cf8', rgb: '129,140,248' },
      { id: 3, color: '#f97316', rgb: '249,115,22' },
    ];

    function switchAct(targetId) {
      actsConfig.forEach(function(act) {
        var tab   = document.getElementById('tab-act' + act.id);
        var panel = document.getElementById('panel-act' + act.id);
        if (!tab || !panel) return;

        var isActive = act.id === targetId;
        panel.style.display = isActive ? '' : 'none';
        tab.setAttribute('aria-selected', isActive ? 'true' : 'false');

        if (isActive) {
          tab.style.border      = '1px solid ' + act.color;
          tab.style.background  = 'rgba(' + act.rgb + ',0.15)';
          tab.style.color       = act.color;
        } else {
          tab.style.border      = '1px solid rgba(' + act.rgb + ',0.35)';
          tab.style.background  = 'transparent';
          tab.style.color       = act.color;
        }
      });
    }

    actsConfig.forEach(function(act) {
      var btn = document.getElementById('tab-act' + act.id);
      if (btn) {
        btn.addEventListener('click', function() { switchAct(act.id); });
      }
    });

    // ── Cacher le spinner quand chaque iframe est chargée ────────────
    actsConfig.forEach(function(act) {
      var iframe  = document.getElementById('iframe-act' + act.id);
      var spinner = document.getElementById('loading-' + act.id);
      if (iframe && spinner) {
        iframe.addEventListener('load', function() {
          spinner.style.display = 'none';
        });
        // Timeout de sécurité : si l'iframe bloque l'embed, on cache quand même le spinner
        setTimeout(function() {
          spinner.style.opacity = '0';
          setTimeout(function() { spinner.style.display = 'none'; }, 400);
        }, 8000);
      }
    });
  </script>
</BaseLayout>
