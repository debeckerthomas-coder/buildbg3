---
// src/pages/outils/index.astro
// Page d'accueil Outils — liste les outils disponibles

import BaseLayout from '../../layouts/BaseLayout.astro';
import TopBar from '../../components/TopBar.astro';

const currentPath = Astro.url.pathname;

const tools = [
  {
    href: '/outils/carte',
    title: 'Carte Interactive',
    description: 'Explorez Faerûn acte par acte via MapGenie — quêtes, boss, équipement BiS Lockadin et points clés Mode Honneur.',
    icon: `<polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/><line x1="9" x2="9" y1="3" y2="18"/><line x1="15" x2="15" y1="6" y2="21"/>`,
    color: '#818cf8',
    tag: 'MapGenie',
  },
  {
    href: '/outils/build-planner',
    title: 'Mini Build-Planner',
    description: 'Planifiez votre répartition Paladin / Occultiste niveau par niveau. Progression, ressources et presets recommandés.',
    icon: `<path d="M14.5 10c-.83 0-1.5-.67-1.5-1.5v-5c0-.83.67-1.5 1.5-1.5s1.5.67 1.5 1.5v5c0 .83-.67 1.5-1.5 1.5z"/><path d="M20.5 10H19V8.5c0-.83.67-1.5 1.5-1.5s1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/><path d="M9.5 14c.83 0 1.5.67 1.5 1.5v5c0 .83-.67 1.5-1.5 1.5S8 21.33 8 20.5v-5c0-.83.67-1.5 1.5-1.5z"/><path d="M3.5 14H5v1.5c0 .83-.67 1.5-1.5 1.5S2 16.33 2 15.5 2.67 14 3.5 14z"/><path d="M14 14.5c0-.83.67-1.5 1.5-1.5h5c.83 0 1.5.67 1.5 1.5s-.67 1.5-1.5 1.5h-5c-.83 0-1.5-.67-1.5-1.5z"/>`,
    color: '#d4a857',
    tag: 'LocalStorage',
  },
];
---

<BaseLayout
  title="Outils — Guide Lockadin BG3"
  description="Outils interactifs pour votre run Lockadin en Mode Honneur : carte interactive et build-planner."
>
  <TopBar currentSection="outils" currentPath={currentPath} />

  <main class="min-h-screen" style="background: #05060a;">

    <section class="px-4 pt-8 pb-4 max-w-content mx-auto">
      <div class="flex items-center gap-3 mb-2">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
             stroke-linecap="round" stroke-linejoin="round"
             class="w-6 h-6 shrink-0" style="color: #d4a857;" aria-hidden="true">
          <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
        </svg>
        <h1 class="font-display text-2xl" style="color: #d4a857;">Outils</h1>
      </div>
      <p style="color: #9a8a72; font-size: 0.875rem;">
        Compagnons interactifs pour planifier et suivre votre run Lockadin en Mode Honneur.
      </p>
    </section>

    <section class="px-4 pb-16 max-w-content mx-auto">
      <div class="grid gap-4 md:grid-cols-2">
        {tools.map(tool => (
          <a
            href={tool.href}
            style={`display: block; background: rgba(13,15,26,0.8); border: 1px solid rgba(212,168,87,0.15); border-radius: 10px; padding: 1.5rem; text-decoration: none; transition: border-color 0.15s, background 0.15s;`}
            class="group hover:border-gold/40 hover:bg-gold/4"
          >
            <div class="flex items-start gap-4">
              <div style={`width: 2.75rem; height: 2.75rem; border-radius: 8px; background: ${tool.color}18; border: 1px solid ${tool.color}30; display: flex; align-items: center; justify-content: center; flex-shrink: 0;`}>
                <svg viewBox="0 0 24 24" fill="none" stroke={tool.color} stroke-width="1.5"
                     stroke-linecap="round" stroke-linejoin="round"
                     style="width: 1.25rem; height: 1.25rem;" aria-hidden="true">
                  <Fragment set:html={tool.icon} />
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <span class="font-display text-base" style="color: #e8dcc8;">{tool.title}</span>
                  <span style={`font-size: 0.65rem; font-family: var(--font-ui, sans-serif); text-transform: uppercase; letter-spacing: 0.08em; color: ${tool.color}; background: ${tool.color}15; border: 1px solid ${tool.color}25; padding: 1px 6px; border-radius: 3px;`}>
                    {tool.tag}
                  </span>
                </div>
                <p style="color: #7a6a58; font-size: 0.82rem; line-height: 1.5; margin: 0;">
                  {tool.description}
                </p>
              </div>
            </div>
            <div class="flex justify-end mt-3">
              <span style={`font-size: 0.75rem; font-family: var(--font-ui, sans-serif); font-weight: 600; color: ${tool.color};`}>
                Ouvrir →
              </span>
            </div>
          </a>
        ))}
      </div>
    </section>

  </main>
</BaseLayout>
