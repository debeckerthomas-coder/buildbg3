---
// src/pages/index.astro
// Page d'accueil — Dashboard du guide

import BaseLayout from '../layouts/BaseLayout.astro';
import TopBar from '../components/TopBar.astro';
import { navigationBySection } from '../data/navigation';

const playthrough = navigationBySection.playthrough;
const grimoire    = navigationBySection.grimoire;

// Icônes SVG inline
const icons: Record<string, string> = {
  Tent:       `<path d="M3.5 21 14 3"/><path d="M20.5 21 10 3"/><path d="M15.5 21 12 15l-3.5 6"/><path d="M2 21h20"/>`,
  Moon:       `<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>`,
  Castle:     `<path d="M22 20v-9H2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2Z"/><path d="M18 11V4H6v7"/><path d="M15 22v-4a3 3 0 0 0-3-3v0a3 3 0 0 0-3 3v4"/><path d="M2 11h20"/><path d="M18 4h.01"/><path d="M6 4h.01"/><path d="M10 4h.01"/><path d="M14 4h.01"/>`,
  Swords:     `<polyline points="14.5 17.5 3 6 3 3 6 3 17.5 14.5"/><line x1="13" x2="19" y1="19" y2="13"/><line x1="16" x2="20" y1="16" y2="20"/><line x1="19" x2="21" y1="21" y2="19"/>`,
  Shield:     `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
  Users:      `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
  Flame:      `<path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/>`,
  HelpCircle: `<circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/>`,
};
---

<BaseLayout title="Accueil" description="Guide ultime Lockadin BG3 — Compagnon de route Mode Honneur">
  <TopBar currentSection="home" currentPath="/" />

  <main class="max-w-content mx-auto px-4 md:px-8 py-10">

    <!-- ── Hero ─────────────────────────────────────────────── -->
    <section class="text-center mb-16 animate-fade-in" aria-labelledby="hero-title">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full
                  bg-gold/10 border border-gold/25 mb-6
                  font-ui text-xs text-gold uppercase tracking-widest">
        <span>Mode Honneur</span>
        <span class="w-1 h-1 rounded-full bg-gold inline-block"></span>
        <span>Sauvegarde unique</span>
      </div>

      <h1 id="hero-title"
          class="font-display text-4xl md:text-5xl lg:text-6xl text-shimmer mb-4 leading-tight">
        Guide Lockadin BG3
      </h1>

      <p class="font-body text-text-secondary text-lg max-w-2xl mx-auto leading-relaxed mb-8">
        Compagnon de route complet pour le build <strong class="text-text-primary">Paladin&nbsp;7&nbsp;/&nbsp;Occultiste&nbsp;5</strong>
        en Mode Honneur. Walkthrough pas-à-pas, équipement BiS, stratégies de boss.
      </p>

      <!-- Badges -->
      <div class="flex flex-wrap justify-center gap-2 mb-10">
        {[
          { label: 'Vanilla — Aucun mod', color: 'gold' },
          { label: 'Zéro exploit', color: 'gold' },
          { label: 'BG3 Patch 7+', color: 'info' },
          { label: '~80h de jeu', color: 'info' },
        ].map(b => (
          <span class:list={[
            'badge',
            b.color === 'gold' ? 'badge-gold' : 'badge-info'
          ]}>
            {b.label}
          </span>
        ))}
      </div>

      <!-- CTA principal -->
      <a href="/playthrough/acte1"
         class="inline-flex items-center gap-3 px-6 py-3 rounded-lg
                bg-gold/20 text-gold-light border border-gold/40 font-ui font-medium
                hover:bg-gold/30 hover:border-gold/60 hover:shadow-gold-md
                transition-all duration-200 text-base">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
             class="w-5 h-5" aria-hidden="true">
          <polygon points="5 3 19 12 5 21 5 3"/>
        </svg>
        Commencer l'aventure — Acte 1
      </a>
    </section>

    <hr class="divider-gold" />

    <!-- ── Section Playthrough ───────────────────────────────── -->
    <section class="mb-14 reveal" aria-labelledby="section-playthrough">
      <div class="flex items-center gap-3 mb-6">
        <h2 id="section-playthrough"
            class="font-heading text-xl text-gold-light tracking-wide">
          Aventure pas-à-pas
        </h2>
        <span class="badge badge-gold text-[10px]">Playthrough</span>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {playthrough.map((page, i) => (
          <a
            href={page.href}
            class="card-bg-hover group block p-5 rounded-xl
                   animate-fade-in"
            style={`animation-delay: ${i * 80}ms`}
          >
            <div class="flex items-start gap-3">
              <div class="w-9 h-9 rounded-lg shrink-0 flex items-center justify-center
                          bg-gold/12 border border-gold/20
                          group-hover:bg-gold/20 group-hover:border-gold/40
                          transition-all duration-200">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"
                     class="w-4 h-4 text-gold" aria-hidden="true">
                  <Fragment set:html={icons[page.icon] ?? ''} />
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <div class="font-ui text-[10px] uppercase tracking-widest text-text-muted mb-0.5">
                  Acte {page.act}
                </div>
                <div class="font-heading text-sm text-text-primary group-hover:text-gold-light
                            transition-colors truncate">
                  {page.shortLabel ?? page.label}
                </div>
                <div class="font-ui text-xs text-text-muted mt-1">
                  {page.navSections.length} sections
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- ── Section Grimoire ──────────────────────────────────── -->
    <section class="mb-14 reveal" aria-labelledby="section-grimoire">
      <div class="flex items-center gap-3 mb-6">
        <h2 id="section-grimoire"
            class="font-heading text-xl text-gold-light tracking-wide">
          Grimoire de référence
        </h2>
        <span class="badge badge-info text-[10px]">Référence</span>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {grimoire.map((page, i) => (
          <a
            href={page.href}
            class="card-bg-hover group block p-5 rounded-xl
                   animate-fade-in"
            style={`animation-delay: ${(i + 3) * 80}ms`}
          >
            <div class="flex items-start gap-3">
              <div class="w-9 h-9 rounded-lg shrink-0 flex items-center justify-center
                          bg-bg-surface border border-white/8
                          group-hover:bg-bg-raised group-hover:border-gold/20
                          transition-all duration-200">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"
                     class="w-4 h-4 text-text-secondary group-hover:text-gold
                            transition-colors" aria-hidden="true">
                  <Fragment set:html={icons[page.icon] ?? ''} />
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <div class="font-heading text-sm text-text-primary group-hover:text-gold-light
                            transition-colors">
                  {page.label}
                </div>
                <div class="font-ui text-xs text-text-muted mt-1">
                  Partie {page.part}
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- ── Encart Mode Honneur ────────────────────────────────── -->
    <section class="reveal mb-10" aria-labelledby="honour-mode-intro">
      <div class="callout-danger rounded-xl p-6">
        <div class="flex items-start gap-3">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
               class="w-5 h-5 shrink-0 mt-0.5 text-danger" aria-hidden="true">
            <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
            <line x1="12" x2="12" y1="9" y2="13"/><line x1="12" x2="12.01" y1="17" y2="17"/>
          </svg>
          <div>
            <h2 id="honour-mode-intro"
                class="font-heading text-base text-danger mb-1">
              Mode Honneur — Règles spéciales
            </h2>
            <p class="font-body text-sm text-danger/80 leading-relaxed">
              Ce guide est optimisé pour le Mode Honneur de BG3 (patch 7+).
              <strong class="text-danger">Une seule sauvegarde. Mort = Game Over définitif.</strong>
              Les stratégies tiennent compte des <em>Actions Légendaires</em> des boss
              et du nerf Extra Attaque (plus de cumul Paladin + Occultiste).
            </p>
          </div>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
