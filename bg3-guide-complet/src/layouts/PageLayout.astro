---
// src/layouts/PageLayout.astro
// Layout "Piggyback" complet :
//   TopBar globale
//   └─ [Sidebar contextuelle] | [Colonne contenu 65%] | [Colonne encarts 35%]
//
// Usage dans un MDX :
//   import PageLayout from '@/layouts/PageLayout.astro';
//   <PageLayout frontmatter={frontmatter}>...</PageLayout>
//
// Props frontmatter attendues (via env.d.ts PageFrontmatter) :
//   title, description, section, act?, part?, checklistStorageKey?

import BaseLayout from './BaseLayout.astro';
import TopBar from '../components/TopBar.astro';
import ContextSidebar from '../components/ContextSidebar.astro';
import PageNav from '../components/PageNav.astro';
import { getCurrentPage, type SectionKey } from '../data/navigation';

// Support double mode d'appel :
//   1. Depuis MDX avec <PageLayout frontmatter={frontmatter}>
//   2. Depuis .astro avec props directes
interface Props {
  frontmatter?: {
    title: string;
    description?: string;
    section: SectionKey;
    act?: 1 | 2 | 3;
  };
  title?: string;
  description?: string;
  section?: SectionKey;
}

// Résolution des props (frontmatter prioritaire)
const fm = Astro.props.frontmatter ?? {};
const title       = fm.title       ?? Astro.props.title       ?? 'Guide Lockadin BG3';
const description = fm.description ?? Astro.props.description ?? '';
const section     = fm.section     ?? Astro.props.section     ?? 'grimoire';

const currentPath = Astro.url.pathname;
const currentPage = getCurrentPage(currentPath);

// Détermine si on affiche la sidebar contextuelle
const hasSidebar = !!currentPage && section !== 'dashboard';
---

<BaseLayout {title} {description}>
  <!-- Top-bar fixe -->
  <TopBar currentSection={section} currentPath={currentPath} />

  <!-- Wrapper principal pleine hauteur -->
  <div class="flex min-h-[calc(100vh-3.5rem)]">

    <!-- ── Sidebar contextuelle (desktop uniquement) ─────────── -->
    {hasSidebar && (
      <ContextSidebar page={currentPage} currentPath={currentPath} />
    )}

    <!-- ── Zone de contenu principale ──────────────────────────
         Grille asymétrique : 65% contenu | 35% encarts
         Sur mobile : 1 colonne
    ── -->
    <main
      id="main-content"
      class:list={[
        'flex-1 min-w-0',
        // Padding responsive
        'px-4 py-6 md:px-6 lg:px-8 xl:px-10',
      ]}
      aria-label="Contenu principal"
    >
      <!-- En-tête de page -->
      <header class="mb-8 reveal">
        <div class="font-ui text-xs uppercase tracking-widest text-text-muted mb-2">
          {section === 'playthrough' && 'Mode Honneur · Aventure'}
          {section === 'grimoire'    && 'Grimoire · Référence'}
          {section === 'dashboard'   && 'Tableau de bord'}
        </div>
        <h1 class="font-display text-2xl md:text-3xl text-gold-light leading-tight">
          {title}
        </h1>
        {description && (
          <p class="mt-2 font-body text-text-secondary max-w-2xl leading-relaxed">
            {description}
          </p>
        )}
        <!-- Filet décoratif -->
        <div class="mt-4 h-px max-w-xl
                    bg-gradient-to-r from-gold/40 via-gold/20 to-transparent">
        </div>
      </header>

      <!-- ── Grille Piggyback ────────────────────────────────── -->
      <div class:list={[
        'piggyback-grid',
        // 2 colonnes sur ≥ xl, 1 colonne sur mobile/tablet
        'grid grid-cols-1 xl:grid-cols-[1fr_22rem] gap-8 xl:gap-10',
        // Alignement : contenu en haut
        'items-start',
      ]}>

        <!-- Colonne gauche (65%) : contenu MDX -->
        <div
          class="prose-bg3 prose max-w-none
                 font-body text-text-primary"
          id="page-content"
        >
          <slot name="content" />
          <!-- Fallback : contenu sans slot nommé -->
          <slot />
        </div>

        <!-- Colonne droite (35%) : encarts contextuels -->
        <aside
          class="space-y-4 xl:sticky xl:top-20
                 xl:max-h-[calc(100vh-6rem)] xl:overflow-y-auto"
          aria-label="Encarts contextuels"
          id="sidebar-encarts"
        >
          <slot name="encarts" />
        </aside>

      </div>

      <!-- ── Navigation précédent / suivant ────────────────── -->
      <PageNav currentPath={currentPath} />

    </main>

  </div>

  <!-- ── Bottom progress bar (mobile) ────────────────────────── -->
  <div
    id="bottom-progress-bar"
    class="fixed bottom-0 left-0 right-0 h-0.5 z-50
           xl:hidden"
    aria-hidden="true"
  >
    <div
      id="bottom-progress-fill"
      class="h-full bg-gradient-to-r from-gold/60 to-gold
             transition-all duration-300"
      style="width: 0%"
    ></div>
  </div>

  <!-- Logique scroll : met à jour la barre de progression de lecture -->
  <script>
    (function initReadingProgress() {
      const fill = document.getElementById('bottom-progress-fill');
      const content = document.getElementById('page-content');
      if (!fill || !content) return;

      const update = () => {
        const rect    = content.getBoundingClientRect();
        const total   = content.offsetHeight;
        const scrolled = Math.max(0, -rect.top + window.innerHeight * 0.5);
        const pct = Math.min(100, (scrolled / total) * 100);
        fill.style.width = `${pct}%`;
      };

      window.addEventListener('scroll', update, { passive: true });
      update();
    })();
  </script>

</BaseLayout>

<!-- ── Styles layout spécifiques ────────────────────────────────
   Les styles Tailwind du prose BG3 sont définis dans tailwind.config.js
   sous typography.bg3. On les applique ici via la classe prose-bg3.
── -->
<style>
  /* Assure que les sections MDX s'affichent en block pour IntersectionObserver */
  :global(section[id]) {
    scroll-margin-top: 5rem; /* topbar (56px) + marge */
  }

  /* Scrollbar fine dans la colonne encarts */
  #sidebar-encarts::-webkit-scrollbar       { width: 4px; }
  #sidebar-encarts::-webkit-scrollbar-track { background: transparent; }
  #sidebar-encarts::-webkit-scrollbar-thumb { background: rgba(212,168,87,0.2); border-radius: 2px; }
</style>
