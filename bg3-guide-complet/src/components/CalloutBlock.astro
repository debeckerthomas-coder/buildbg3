---
// src/components/CalloutBlock.astro
// Callout inline pour la COLONNE GAUCHE du Piggyback (dans le flux de contenu)
// Contrairement à Encart.astro (colonne droite), celui-ci s'insère dans le texte
//
// Types :
//   danger  → Alerte mode Honneur (mort possible)
//   warning → Attention / piège
//   loot    → Loot important dans le texte
//   tip     → Conseil tactique
//   info    → Information mécanique
//   secret  → Contenu optionnel / secret
//
// Usage MDX :
//   <CalloutBlock type="danger">
//     Ne combattez **jamais** Zhalk au Prologue — combattez les Cambions à la place.
//   </CalloutBlock>

type CalloutType = 'danger' | 'warning' | 'loot' | 'tip' | 'info' | 'secret';

interface Props {
  type: CalloutType;
  title?: string;         // titre optionnel
  class?: string;
}

const { type, title, class: extraClass = '' } = Astro.props;

const cfg: Record<CalloutType, {
  border: string; bg: string; icon: string; iconColor: string;
  defaultTitle: string; textColor: string;
}> = {
  danger: {
    border:   'border-danger/50',
    bg:       'bg-danger/6',
    icon:     '<path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" x2="12" y1="9" y2="13"/><line x1="12" x2="12.01" y1="17" y2="17"/>',
    iconColor:'text-danger',
    defaultTitle: 'Alerte Mode Honneur',
    textColor:'text-danger/80',
  },
  warning: {
    border:   'border-amber/40',
    bg:       'bg-amber/5',
    icon:     '<path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" x2="12" y1="9" y2="13"/><line x1="12" x2="12.01" y1="17" y2="17"/>',
    iconColor:'text-amber',
    defaultTitle: 'Attention',
    textColor:'text-amber/80',
  },
  loot: {
    border:   'border-gold/35',
    bg:       'bg-gold/5',
    icon:     '<circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/>',
    iconColor:'text-gold',
    defaultTitle: 'Loot important',
    textColor:'text-gold-light/90',
  },
  tip: {
    border:   'border-emerald/35',
    bg:       'bg-emerald/5',
    icon:     '<path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/>',
    iconColor:'text-emerald',
    defaultTitle: 'Conseil',
    textColor:'text-emerald/80',
  },
  info: {
    border:   'border-blue-400/30',
    bg:       'bg-blue-500/5',
    icon:     '<circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/>',
    iconColor:'text-blue-400',
    defaultTitle: 'Mécanique',
    textColor:'text-blue-300/80',
  },
  secret: {
    border:   'border-violet/30',
    bg:       'bg-violet/5',
    icon:     '<rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>',
    iconColor:'text-violet-light',
    defaultTitle: 'Secret',
    textColor:'text-violet-light/80',
  },
};

const c = cfg[type];
const displayTitle = title ?? c.defaultTitle;
---

<div
  class:list={[
    'callout-block rounded-lg border-l-[3px] px-4 py-3 my-4',
    'not-prose',            // sort du mode prose Tailwind pour ce bloc
    c.border, c.bg,
    extraClass,
  ]}
>
  <!-- Titre avec icône -->
  <div class:list={['flex items-center gap-2 mb-1.5', c.iconColor]}>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
         stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
         class="w-3.5 h-3.5 shrink-0" aria-hidden="true">
      <Fragment set:html={c.icon} />
    </svg>
    <span class="font-ui text-xs font-semibold uppercase tracking-wide">
      {displayTitle}
    </span>
  </div>

  <!-- Contenu avec Markdown transformé -->
  <div class:list={[
    'font-body text-sm leading-relaxed',
    c.textColor,
    '[&_strong]:font-bold [&_strong]:text-inherit',
    '[&_em]:italic',
    '[&_code]:font-mono [&_code]:text-xs [&_code]:bg-white/5 [&_code]:px-1 [&_code]:rounded',
    '[&_a]:underline [&_a]:decoration-current',
    '[&_ul]:list-disc [&_ul]:pl-4 [&_ul]:space-y-0.5',
    '[&_li]:leading-snug',
  ]}>
    <slot />
  </div>
</div>
