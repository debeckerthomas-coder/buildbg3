---
// src/components/ContextSidebar.astro
// Sidebar contextuelle : sommaire de la page courante uniquement
// S'affiche à gauche dans le layout Piggyback

import type { NavPage } from '../data/navigation';

interface Props {
  page: NavPage | undefined;
  currentPath: string;
}

const { page } = Astro.props;

// Icônes inline pour la sidebar (Lucide SVG paths)
const sectionIcon = `<path d="M4 6h16M4 12h8M4 18h12"/>`;  // AlignLeft
const checkIcon   = `<polyline points="20 6 9 17 4 12"/>`;     // Check

// Label de section
const sectionLabels: Record<string, string> = {
  playthrough: 'Aventure',
  grimoire:    'Grimoire',
};
---

{page && (
  <aside
    id="context-sidebar"
    class="sticky top-14 h-[calc(100vh-3.5rem)] overflow-y-auto
           w-[17rem] shrink-0 hidden lg:flex flex-col
           border-r border-gold/[0.08]"
    style="background: rgba(8,10,18,0.85); box-shadow: inset -1px 0 0 rgba(212,168,87,0.06);"
    aria-label="Sommaire de la page"
  >
    <!-- Filet doré en haut -->
    <div class="h-px bg-gradient-to-r from-transparent via-gold/30 to-transparent shrink-0"></div>

    <!-- Header sidebar -->
    <div class="px-4 pt-4 pb-3 border-b border-gold/[0.08] shrink-0">
      <!-- Fil d'Ariane section -->
      {page.section !== 'dashboard' && (
        <div class="font-ui text-[10px] uppercase tracking-widest text-text-muted mb-1">
          {sectionLabels[page.section] ?? page.section}
        </div>
      )}
      <!-- Titre de la page -->
      <div class="font-heading text-sm text-gold-light leading-snug">
        {page.label}
      </div>
    </div>

    <!-- Sommaire (TOC) -->
    <nav class="flex-1 px-3 py-3 space-y-0.5 overflow-y-auto min-h-0" aria-label="Sommaire">
      {page.navSections.map((section) => {
        const isChecklist = section.label.startsWith('✓');
        return (
          <a
            href={`#${section.id}`}
            class:list={[
              'toc-link flex items-center gap-2.5 px-2.5 py-1.5 rounded-md text-xs',
              'font-ui transition-all duration-200 group',
              'text-text-secondary border border-transparent',
              'hover:text-text-primary hover:bg-gold/[0.07] hover:border-gold/[0.12]',
              isChecklist
                ? 'text-emerald/80 hover:text-emerald hover:bg-emerald/[0.07]'
                : '',
            ]}
            data-section-id={section.id}
          >
            <span class:list={[
              'flex-shrink-0 w-3.5 h-3.5 opacity-40 group-hover:opacity-90 transition-opacity duration-200',
              isChecklist ? 'text-emerald' : 'text-gold',
            ]}>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                   stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                   class="w-full h-full" aria-hidden="true">
                {isChecklist
                  ? <Fragment set:html={checkIcon} />
                  : <Fragment set:html={sectionIcon} />
                }
              </svg>
            </span>
            <span class="leading-tight truncate">{section.label}</span>
          </a>
        );
      })}
    </nav>

    <!-- Navigation entre pages (précédent / suivant) -->
    <div class="border-t border-gold/[0.08] px-3 py-3 space-y-1 shrink-0" id="sidebar-page-nav">
      <!-- Rempli par JS client -->
    </div>

  </aside>
)}

<!-- Active TOC link highlighting via IntersectionObserver -->
<script>
  // Highlight le lien TOC correspondant à la section visible
  (function initTOC() {
    const links = document.querySelectorAll<HTMLAnchorElement>('.toc-link[data-section-id]');
    if (!links.length) return;

    // Classes pour l'état actif (mis en data-attr pour éviter les conflits Tailwind purge)
    function setActive(link: HTMLElement) {
      link.style.color = '#f0d090';
      link.style.background = 'rgba(212,168,87,0.12)';
      link.style.borderColor = 'rgba(212,168,87,0.25)';
      link.style.fontWeight = '600';
      // Icône : rendre visible
      const icon = link.querySelector('span');
      if (icon) icon.style.opacity = '1';
    }

    function setInactive(link: HTMLElement) {
      link.style.color = '';
      link.style.background = '';
      link.style.borderColor = '';
      link.style.fontWeight = '';
      const icon = link.querySelector('span');
      if (icon) icon.style.opacity = '';
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          const id = entry.target.id;
          const link = document.querySelector<HTMLElement>(`.toc-link[data-section-id="${id}"]`);
          if (!link) return;
          if (entry.isIntersecting) {
            links.forEach(l => setInactive(l as HTMLElement));
            setActive(link);
            // Scroll le lien actif dans la vue si nécessaire
            link.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
          }
        });
      },
      { rootMargin: '-14% 0px -80% 0px', threshold: 0 }
    );

    links.forEach(link => {
      const id = link.dataset.sectionId;
      if (id) {
        const target = document.getElementById(id);
        if (target) observer.observe(target);
      }
    });
  })();
</script>
