---
// src/components/LootItem.astro
// Composant d'item de loot pour la colonne droite
// Usage dans MDX à l'intérieur d'un <Encart type="loot"> :
//
//   <LootItem
//     name="Lame Éternelle"
//     type="Épée longue"
//     rarity="uncommon"
//     stats="+1d4 Feu"
//     location="Nautiloïde — Commandant Zhalk"
//     note="Prenez-la avec Lae'zel avant de fuir"
//     bis
//   />

type Rarity = 'common' | 'uncommon' | 'rare' | 'very-rare' | 'legendary';

interface Props {
  name: string;
  type?: string;           // "Épée longue", "Armure lourde", etc.
  rarity?: Rarity;
  stats?: string;          // Stats courtes : "+2 CA", "1d8+3 Feu+Radiant", etc.
  location?: string;       // Où le trouver
  note?: string;           // Conseil court
  bis?: boolean;           // Badge "BiS"
  optional?: boolean;      // Grisé + badge "Optionnel"
}

const {
  name,
  type,
  rarity = 'rare',
  stats,
  location,
  note,
  bis = false,
  optional = false,
} = Astro.props;

const rarityConfig: Record<Rarity, { color: string; label: string }> = {
  common:    { color: '#a8a0b8', label: 'Commun' },
  uncommon:  { color: '#10b981', label: 'Inhabituel' },
  rare:      { color: '#3b82f6', label: 'Rare' },
  'very-rare': { color: '#8b5cf6', label: 'Très rare' },
  legendary: { color: '#f59e0b', label: 'Légendaire' },
};

const rc = rarityConfig[rarity];

// Icône SVG pin pour la localisation
const pinIcon = `<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>`;
// Icône stats (dés)
const diceIcon = `<rect width="12" height="12" x="2" y="10" rx="2" ry="2"/><path d="m17.92 14 3.5-3.5a2.24 2.24 0 0 0 0-3l-5-4.92a2.24 2.24 0 0 0-3 0L10 6"/><path d="M6 18h.01"/><path d="M10 14h.01"/>`;
---

<div
  class:list={[
    'flex items-start gap-3 py-2.5 border-b border-white/5 last:border-0',
    optional && 'opacity-60',
  ]}
>
  <!-- Point de rareté coloré -->
  <div
    class="w-1.5 h-1.5 rounded-full shrink-0 mt-1.5"
    style={`background: ${rc.color}; box-shadow: 0 0 6px ${rc.color}60;`}
    title={rc.label}
    aria-label={`Rareté : ${rc.label}`}
  ></div>

  <!-- Infos item -->
  <div class="flex-1 min-w-0">
    <!-- Nom + badges -->
    <div class="flex items-start gap-2 flex-wrap">
      <span class="font-ui text-sm font-semibold text-text-primary leading-snug">
        {name}
      </span>
      {bis && (
        <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[9px]
                     font-ui font-bold uppercase tracking-wide
                     bg-gold/15 text-gold border border-gold/35"
              aria-label="Meilleur en emplacement">
          BiS
        </span>
      )}
      {optional && (
        <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[9px]
                     font-ui uppercase tracking-wide
                     bg-white/5 text-text-muted border border-white/10">
          Optionnel
        </span>
      )}
    </div>

    <!-- Type + rareté -->
    {type && (
      <div class="font-ui text-[10px] mt-0.5 leading-none"
           style={`color: ${rc.color};`}>
        {type} · {rc.label}
      </div>
    )}

    <!-- Stats -->
    {stats && (
      <div class="flex items-center gap-1.5 mt-1.5">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"
             class="w-3 h-3 text-gold/50 shrink-0" aria-hidden="true">
          <Fragment set:html={diceIcon} />
        </svg>
        <code class="font-mono text-[11px] text-gold-pale bg-gold/8 px-1.5 py-0.5 rounded">
          {stats}
        </code>
      </div>
    )}

    <!-- Localisation -->
    {location && (
      <div class="flex items-start gap-1.5 mt-1">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"
             class="w-3 h-3 text-text-dim shrink-0 mt-0.5" aria-hidden="true">
          <Fragment set:html={pinIcon} />
        </svg>
        <span class="font-ui text-[11px] text-text-muted leading-snug">
          {location}
        </span>
      </div>
    )}

    <!-- Note -->
    {note && (
      <div class="mt-1.5 text-[11px] font-body text-text-secondary italic leading-snug
                  pl-2 border-l border-gold/20">
        {note}
      </div>
    )}
  </div>
</div>
