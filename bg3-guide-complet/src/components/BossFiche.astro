---
// src/components/BossFiche.astro
// Fiche synthétique d'un boss pour la colonne droite
// Usage MDX :
//
//   <BossFiche
//     name="Ansur — Dragon de Tempête"
//     hp={500}
//     location="Wyrmway, sous la Ville Basse"
//     legendary="Nova de Cœur-de-Tempête — 8d10 Foudre + Étourdissement zone"
//     slot="encarts"
//   >
//     <BossWeakness>Silence Tour 1 — annule la Légendaire</BossWeakness>
//     <BossWeakness>Globle d'invulnérabilité — protège l'équipe</BossWeakness>
//   </BossFiche>

interface Props {
  name: string;
  hp: number;
  location?: string;
  legendary?: string;     // description de l'action légendaire
  difficulty?: 1 | 2 | 3 | 4 | 5;  // 1-5 étoiles
  class?: string;
}

const { name, hp, location, legendary, difficulty = 3, class: extraClass = '' } = Astro.props;

// Couleur HP selon montant
const hpColor = hp > 500 ? '#ef4444' : hp > 300 ? '#f97316' : '#f59e0b';

// Icônes
const skullIcon = `<path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v11m0 0H5a2 2 0 0 1-2-2V9m6 5h10a2 2 0 0 0 2-2V9m0 0H3"/>`;
const pinIcon   = `<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>`;
const zapIcon   = `<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>`;
---

<div
  class:list={[
    'boss-fiche rounded-xl overflow-hidden',
    'border border-danger/30',
    extraClass,
  ]}
  style="background: rgba(12,5,5,0.8);"
>
  <!-- Header rouge -->
  <div class="px-4 py-3 border-b border-danger/25"
       style="background: rgba(239,68,68,0.08);">
    <div class="font-ui text-[9px] uppercase tracking-widest text-danger/70 mb-0.5">
      👹 Fiche Boss
    </div>
    <div class="font-heading text-sm text-red-300 leading-snug">
      {name}
    </div>

    <!-- Difficulté -->
    <div class="flex items-center gap-1 mt-1.5" aria-label={`Difficulté : ${difficulty}/5`}>
      {Array.from({ length: 5 }).map((_, i) => (
        <div
          class:list={[
            'w-2 h-2 rounded-sm',
            i < difficulty ? 'bg-danger' : 'bg-white/10',
          ]}
          aria-hidden="true"
        />
      ))}
      <span class="font-ui text-[10px] text-danger/60 ml-1">
        {difficulty === 5 ? 'Létal' : difficulty >= 4 ? 'Extrême' : difficulty >= 3 ? 'Difficile' : 'Modéré'}
      </span>
    </div>
  </div>

  <!-- Stats -->
  <div class="px-4 py-3 space-y-2.5">
    <!-- PV -->
    <div class="flex items-center justify-between">
      <span class="font-ui text-xs text-text-muted flex items-center gap-1.5">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
             class="w-3 h-3" aria-hidden="true">
          <Fragment set:html={skullIcon} />
        </svg>
        Points de vie
      </span>
      <span class="font-mono text-sm font-bold" style={`color: ${hpColor};`}>
        {hp} PV
      </span>
    </div>

    <!-- Localisation -->
    {location && (
      <div class="flex items-start gap-1.5">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
             class="w-3 h-3 text-text-dim shrink-0 mt-0.5" aria-hidden="true">
          <Fragment set:html={pinIcon} />
        </svg>
        <span class="font-ui text-[11px] text-text-muted leading-snug">
          {location}
        </span>
      </div>
    )}

    <!-- Action légendaire -->
    {legendary && (
      <div class="rounded-lg border border-danger/20 bg-danger/5 px-3 py-2">
        <div class="flex items-center gap-1.5 mb-1">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
               class="w-3 h-3 text-danger shrink-0" aria-hidden="true">
            <Fragment set:html={zapIcon} />
          </svg>
          <span class="font-ui text-[9px] uppercase tracking-widest text-danger/70">
            Action Légendaire
          </span>
        </div>
        <span class="font-body text-xs text-danger/80 leading-snug">
          {legendary}
        </span>
      </div>
    )}

    <!-- Faiblesses / contre-stratégies -->
    <div class="space-y-1">
      <div class="font-ui text-[10px] uppercase tracking-widest text-text-muted mb-1.5">
        ⚔ Stratégies clés
      </div>
      <slot />
    </div>
  </div>
</div>
