---
// src/components/BossWeakness.astro
// Item de stratégie pour BossFiche
// Usage :
//   <BossWeakness priority="critical">Lancez Silence Tour 1</BossWeakness>
//   <BossWeakness>Dégâts Radiants contournent la résistance physique</BossWeakness>

interface Props {
  priority?: 'critical' | 'normal';
}

const { priority = 'normal' } = Astro.props;

const checkIcon = `<polyline points="20 6 9 17 4 12"/>`;
---

<div class:list={[
  'flex items-start gap-2 text-xs font-body leading-snug',
  priority === 'critical' ? 'text-gold/90' : 'text-text-secondary',
]}>
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
       stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
       class:list={[
         'w-3 h-3 shrink-0 mt-0.5',
         priority === 'critical' ? 'text-gold' : 'text-emerald/60',
       ]}
       aria-hidden="true">
    <Fragment set:html={checkIcon} />
  </svg>
  <span><slot /></span>
</div>
