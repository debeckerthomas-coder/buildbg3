---
// src/components/Encart.astro
// Composant d'encart pour la colonne droite (35%) du layout Piggyback
// Représente les callouts contextuels : alertes, loot, level-up, boss, tip
//
// Usage dans MDX (slot "encarts") :
//
//   <Encart type="danger" title="Alerte Honneur" slot="encarts">
//     Ne combattez pas Zhalk au Prologue.
//   </Encart>
//
//   <Encart type="loot" title="Loot BiS" slot="encarts">
//     <EncartLootItem name="Lame Éternelle" rarity="uncommon" stats="+1d4 Feu" />
//   </Encart>

type EncartType =
  'danger' | 'warning' | 'loot' | 'levelup' | 'tip' | 'info' | 'secret' | 'boss'

interface Props {
  type: EncartType;
  title: string;
  icon?: string;           // surcharge l'icône par défaut du type
  collapsed?: boolean;     // réduit par défaut sur mobile
  class?: string;
}

const { type, title, icon, class: extraClass = '' } = Astro.props;

// ── Config par type ──────────────────────────────────────────────
const config: Record<EncartType, {
  borderColor: string;
  bgColor:     string;
  headerBg:    string;
  titleColor:  string;
  icon:        string;      // SVG path Lucide
  iconColor:   string;
  label:       string;
}> = {
  danger: {
    borderColor: 'rgba(255,59,59,0.35)',
    bgColor:     'rgba(255,59,59,0.04)',
    headerBg:    'rgba(255,59,59,0.08)',
    titleColor:  '#ff3b3b',
    icon:        '<path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" x2="12" y1="9" y2="13"/><line x1="12" x2="12.01" y1="17" y2="17"/>',
    iconColor:   '#ff3b3b',
    label:       '⚠ Alerte Honneur',
  },
  warning: {
    borderColor: 'rgba(245,158,11,0.35)',
    bgColor:     'rgba(245,158,11,0.04)',
    headerBg:    'rgba(245,158,11,0.08)',
    titleColor:  '#f59e0b',
    icon:        '<path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" x2="12" y1="9" y2="13"/><line x1="12" x2="12.01" y1="17" y2="17"/>',
    iconColor:   '#f59e0b',
    label:       'Attention',
  },
  loot: {
    borderColor: 'rgba(212,168,87,0.35)',
    bgColor:     'rgba(212,168,87,0.04)',
    headerBg:    'rgba(212,168,87,0.08)',
    titleColor:  '#f0d090',
    icon:        '<circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/>',
    iconColor:   '#d4a857',
    label:       '🏆 Loot BiS',
  },
  levelup: {
    borderColor: 'rgba(139,92,246,0.35)',
    bgColor:     'rgba(139,92,246,0.04)',
    headerBg:    'rgba(139,92,246,0.08)',
    titleColor:  '#a78bfa',
    icon:        '<polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/>',
    iconColor:   '#8b5cf6',
    label:       'Level Up',
  },
  tip: {
    borderColor: 'rgba(16,185,129,0.35)',
    bgColor:     'rgba(16,185,129,0.04)',
    headerBg:    'rgba(16,185,129,0.08)',
    titleColor:  '#10b981',
    icon:        '<circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/>',
    iconColor:   '#10b981',
    label:       'Conseil',
  },
  info: {
    borderColor: 'rgba(59,130,246,0.35)',
    bgColor:     'rgba(59,130,246,0.04)',
    headerBg:    'rgba(59,130,246,0.08)',
    titleColor:  '#60a5fa',
    icon:        '<circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/>',
    iconColor:   '#3b82f6',
    label:       'Info',
  },
  secret: {
    borderColor: 'rgba(139,92,246,0.25)',
    bgColor:     'rgba(139,92,246,0.03)',
    headerBg:    'rgba(139,92,246,0.06)',
    titleColor:  '#a78bfa',
    icon:        '<rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>',
    iconColor:   '#8b5cf6',
    label:       '🔒 Secret',
  },
  boss: {
    borderColor: 'rgba(239,68,68,0.35)',
    bgColor:     'rgba(239,68,68,0.04)',
    headerBg:    'rgba(239,68,68,0.10)',
    titleColor:  '#f87171',
    icon:        '<path d="M2 20h.01"/><path d="M7 20v-4"/><path d="M12 20v-8"/><path d="M17 20V8"/><path d="M22 4v16"/>',
    iconColor:   '#ef4444',
    label:       '👹 Boss',
  },
};

const cfg = config[type];
const iconPath = icon ?? cfg.icon;
---

<div
  class:list={[
    'encart rounded-xl overflow-hidden text-sm',
    extraClass,
  ]}
  style={`
    border: 1px solid ${cfg.borderColor};
    background: ${cfg.bgColor};
  `}
>
  <!-- Header de l'encart -->
  <div
    class="flex items-center gap-2.5 px-4 py-2.5"
    style={`background: ${cfg.headerBg}; border-bottom: 1px solid ${cfg.borderColor};`}
  >
    <svg
      viewBox="0 0 24 24"
      fill="none"
      stroke={cfg.iconColor}
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="w-4 h-4 shrink-0"
      aria-hidden="true"
    >
      <Fragment set:html={iconPath} />
    </svg>

    <div class="flex-1 min-w-0">
      <!-- Sous-label type -->
      <div class="font-ui text-[9px] uppercase tracking-widest opacity-70"
           style={`color: ${cfg.titleColor};`}>
        {cfg.label}
      </div>
      <!-- Titre de l'encart -->
      <div class="font-heading text-sm leading-snug truncate"
           style={`color: ${cfg.titleColor};`}>
        {title}
      </div>
    </div>
  </div>

  <!-- Contenu -->
  <div class="px-4 py-3 font-body text-text-secondary leading-relaxed space-y-2
              [&_strong]:text-text-primary [&_em]:italic [&_em]:text-text-secondary
              [&_a]:text-gold [&_a:hover]:text-gold-light
              [&_code]:font-mono [&_code]:text-xs [&_code]:bg-white/5
              [&_code]:px-1 [&_code]:py-0.5 [&_code]:rounded">
    <slot />
  </div>
</div>
